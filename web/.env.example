# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres on arcade-data
DATABASE_URL="postgres://openarcade:CHANGE_ME@10.0.1.45:5432/openarcade"

# arcade-api (server browser / live data)
ARCADE_API_URL="http://10.0.1.44:8080"

# Session signing
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Transactional email via Resend. Verify the sending domain arcade.haggabasin.com
# in Resend, then add its DKIM/SPF records to Cloudflare DNS.
EMAIL_FROM="OpenArcade <noreply@arcade.haggabasin.com>"
RESEND_API_KEY=""

# Public URL of the portal (served on arcade.haggabasin.com via the CF tunnel)
NEXT_PUBLIC_SITE_URL="https://arcade.haggabasin.com"
