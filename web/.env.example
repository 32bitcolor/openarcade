# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres on arcade-data
DATABASE_URL="postgres://openarcade:CHANGE_ME@10.0.1.32:5432/openarcade"

# arcade-api (server browser / live data)
ARCADE_API_URL="http://10.0.1.31:8080"

# Session signing
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Transactional email (pick one provider; Resend shown)
EMAIL_FROM="OpenArcade <noreply@YOURDOMAIN>"
RESEND_API_KEY=""
