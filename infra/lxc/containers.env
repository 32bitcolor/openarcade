# OpenArcade LXC inventory — sourced by provision.sh, run ON the Proxmox host.
#
# CTIDs and IPs verified free on the host 2026-07-13 (pct list + ping sweep).
# CTIDs 120-125 unused; IPs .43-.48 are a free contiguous block (.31/.32/.42/.49
# were in use, so the earlier .30-.35 proposal was moved here).

# Debian 12 template present on local storage (verified via `pveam list local`).
TEMPLATE="local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst"
STORAGE="local-lvm"
BRIDGE="vmbr0"
GATEWAY="10.0.1.1"
NAMESERVER="10.0.1.1"
DISK_GB="8"
CORES="2"
MEM_MB="1024"

# hostname | CTID | IP/CIDR | mem(MB) | disk(GB) | role
CONTAINERS=(
  "arcade-core  120 10.0.1.43/24 1024 8  openspy-core (own GameSpy master)"
  "arcade-api   121 10.0.1.44/24 1024 8  Rust aggregator + WebSocket gateway"
  "arcade-data  122 10.0.1.45/24 2048 16 Postgres + Redis"
  "arcade-voice 123 10.0.1.46/24 512  8  Mumble/Murmur"
  "arcade-files 124 10.0.1.47/24 1024 20 Caddy static + news"
  "arcade-web   125 10.0.1.48/24 1024 8  Public site — signup + connect"
)
