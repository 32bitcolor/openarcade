# OpenArcade LXC inventory — sourced by provision.sh, run ON the Proxmox host.
#
# CTIDs and IPs below are PROPOSED defaults. Verify against `pct list` and your
# DHCP/static map before provisioning so nothing collides with existing guests
# (known in use: VM100 @10.0.1.27, LXC106 @10.0.1.219, host @10.0.1.65).

# Debian 12 template on local storage — adjust to whatever `pveam list <storage>` shows.
TEMPLATE="local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst"
STORAGE="local-lvm"
BRIDGE="vmbr0"
GATEWAY="10.0.1.1"
NAMESERVER="10.0.1.1"
DISK_GB="8"
CORES="2"
MEM_MB="1024"

# hostname | CTID | IP/CIDR | mem(MB) | disk(GB) | role
CONTAINERS=(
  "arcade-core  120 10.0.1.30/24 1024 8  openspy-core (own GameSpy master)"
  "arcade-api   121 10.0.1.31/24 1024 8  Rust aggregator + WebSocket gateway"
  "arcade-data  122 10.0.1.32/24 2048 16 Postgres + Redis"
  "arcade-voice 123 10.0.1.33/24 512  8  Mumble/Murmur"
  "arcade-files 124 10.0.1.34/24 1024 20 Caddy static + news"
  "arcade-web   125 10.0.1.35/24 1024 8  Public site — signup + connect"
)
