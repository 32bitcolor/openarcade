{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenArcade",
  "version": "0.0.1",
  "identifier": "com.openarcade.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenArcade",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
